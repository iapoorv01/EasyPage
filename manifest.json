{
  "manifest_version": 3,
  "name": "EasyPage",
  "version": "1.0.0",
  "description": "EasyPage — Clarity for every brain. AI-powered Chrome extension for accessible, simplified, and distraction-free web reading for all minds.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dom-utils.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/easypage16.png",
      "48": "icons/easypage48.png",
      "128": "icons/easypage128.png"
    }
  },
  "icons": {
    "16": "icons/easypage16.png",
    "48": "icons/easypage48.png",
    "128": "icons/easypage128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}